# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=123456:your-telegram-bot-token
ADMIN_IDS=123456789
ADMIN_IDS=500134490

# PostgreSQL (Railway auto-injects this if you link a Postgres plugin)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/technomarket

APP_HOST=0.0.0.0
APP_PORT=8000

# ── Site URL (used for "Open on site" links in bot) ───────────────────────────
# Set to your Railway public URL, e.g. https://technomarket.up.railway.app
SITE_URL=https://your-app.up.railway.app

# ── Cloudinary (optional — for bot photo uploads) ─────────────────────────────
# All three must be set to enable photo upload via bot.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Base upload folder. Subfolders /products and /logos are appended automatically.
CLOUDINARY_FOLDER=shopplatform/technovlada
